# Copy to .env.local for local overrides (not committed).

# GitHub Pages / static export: set a direct MP4 URL so the feature video section plays video.
# Optional locally. In CI, set the same name as a repository Actions secret.
# NEXT_PUBLIC_FEATURE_VIDEO_SRC=https://videos.pexels.com/video-files/.../file.mp4
# Or a file under public/ (leading slash is rewritten when BASE_PATH is set):
# NEXT_PUBLIC_FEATURE_VIDEO_SRC=/videos/your-clip.mp4

# Hero (home) streams YouTube by default (see HeroSection). Override ID or full URL:
# NEXT_PUBLIC_HERO_YOUTUBE_ID=xvInodQv6q0
# NEXT_PUBLIC_HERO_YOUTUBE_URL=https://youtu.be/xvInodQv6q0

# Simulate a GitHub project site locally after `npm run build`:
# PowerShell: $env:BASE_PATH="/YourRepoName"; npm run build; npm run export:serve
